<!DOCTYPE html>
<html lang="da">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Executive Performance Dashboard</title>
<link rel="manifest" href="manifest.json">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body{margin:0;font-family:Inter,system-ui;background:#0f172a;color:#fff;display:flex}
.sidebar{width:240px;background:#111827;padding:25px 15px;height:100vh}
.sidebar h2{font-size:18px;margin-bottom:30px}
.nav-item{padding:12px;border-radius:10px;cursor:pointer;color:#94a3b8;margin-bottom:10px}
.nav-item:hover,.active{background:#1e293b;color:#fff}
.main{flex:1;padding:30px;overflow-y:auto}
.card{background:#1e293b;padding:20px;border-radius:16px;margin-bottom:20px}
.grid{display:grid;gap:20px}
.grid-4{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}
h1{margin-top:0}
select,input{padding:8px;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#fff}
.positive{color:#22c55e}
.negative{color:#ef4444}
.neutral{color:#facc15}
.score{font-size:26px;font-weight:bold}
.small{font-size:13px;color:#94a3b8}
</style>
</head>
<body>

<div class="sidebar">
  <h2>Executive</h2>
  <div class="nav-item active" onclick="navigate('dashboard',this)">Dashboard</div>
  <div class="nav-item" onclick="navigate('year',this)">Årsvisning</div>
</div>

<div class="main" id="content"></div>

<script>

let chartInstance=null;

let data=JSON.parse(localStorage.getItem("execV3"))||{
  vat:25,
  departments:[
    {
      name:"Standard Afdeling",
      budgets:{kitchen:30,bar:18,salary:35},
      months:[]
    }
  ]
};

function save(){localStorage.setItem("execV3",JSON.stringify(data));}

function navigate(view,el){
  document.querySelectorAll(".nav-item").forEach(n=>n.classList.remove("active"));
  el.classList.add("active");
  if(view==="dashboard") renderDashboard();
  if(view==="year") renderYear();
}

function calcPercent(val,rev){return rev?val/rev*100:0;}

function getRevenueNet(m){return m.revenueGross/(1+data.vat/100);}

function renderDashboard(){
  const dep=data.departments[0];
  const latest=dep.months[dep.months.length-1];
  if(!latest){
    document.getElementById("content").innerHTML="<h1>Indtast måned data i koden først</h1>";
    return;
  }
  const rev=getRevenueNet(latest);

  function metric(title,val,budget){
    const p=calcPercent(val,rev);
    const diff=p-budget;
    const cls=diff>0?"negative":"positive";
    return `
    <div class="card">
      <h3>${title}</h3>
      <h2>${p.toFixed(1)}%</h2>
      <div class="${cls}">${diff.toFixed(1)}%</div>
    </div>`;
  }

  document.getElementById("content").innerHTML=`
  <h1>${dep.name}</h1>
  <div class="grid grid-4">
    <div class="card">
      <h3>Omsætning ex moms</h3>
      <h2>${rev.toFixed(0)} kr</h2>
    </div>
    ${metric("Køkken",latest.kitchen,dep.budgets.kitchen)}
    ${metric("Bar",latest.bar,dep.budgets.bar)}
    ${metric("Løn",latest.salary,dep.budgets.salary)}
  </div>
  `;
}

function renderYear(){
  const dep=data.departments[0];
  const years=[...new Set(dep.months.map(m=>m.month.substring(0,4)))];
  if(years.length===0){
    document.getElementById("content").innerHTML="<h1>Ingen data</h1>";
    return;
  }
  const selectedYear=years[years.length-1];
  const months=dep.months.filter(m=>m.month.startsWith(selectedYear));

  let yearOptions=years.map(y=>`<option>${y}</option>`).join("");

  const vatFactor=(1+data.vat/100);

  let totalRev=0,totalK=0,totalB=0,totalS=0;

  months.forEach(m=>{
    const net=m.revenueGross/vatFactor;
    totalRev+=net;
    totalK+=calcPercent(m.kitchen,net);
    totalB+=calcPercent(m.bar,net);
    totalS+=calcPercent(m.salary,net);
  });

  const avgK=totalK/months.length;
  const avgB=totalB/months.length;
  const avgS=totalS/months.length;

  const score=Math.max(0,100-(Math.max(avgK-dep.budgets.kitchen,0)*10));

  document.getElementById("content").innerHTML=`
  <h1>Årsrapport</h1>
  <div class="card">
    År:
    <select onchange="changeYear(this.value)">
      ${yearOptions}
    </select>
  </div>

  <div class="grid grid-4">
    <div class="card"><h3>Års Omsætning</h3><h2>${totalRev.toFixed(0)} kr</h2></div>
    <div class="card"><h3>Gns Køkken</h3><h2>${avgK.toFixed(1)}%</h2></div>
    <div class="card"><h3>Gns Bar</h3><h2>${avgB.toFixed(1)}%</h2></div>
    <div class="card"><h3>Gns Løn</h3><h2>${avgS.toFixed(1)}%</h2></div>
  </div>

  <div class="card">
    <h3>Performance Score</h3>
    <div class="score">${score.toFixed(0)} / 100</div>
  </div>

  <div class="grid grid-4">
    ${renderQuarter(dep,1,selectedYear)}
    ${renderQuarter(dep,2,selectedYear)}
    ${renderQuarter(dep,3,selectedYear)}
    ${renderQuarter(dep,4,selectedYear)}
  </div>

  <div class="card">
    <canvas id="yearChart"></canvas>
  </div>
  `;

  renderYearChart(months,dep);
}

function renderQuarter(dep,q,year){
  const vatFactor=(1+data.vat/100);
  const months=dep.months.filter(m=>{
    if(!m.month.startsWith(year)) return false;
    const monthIndex=new Date(m.month).getMonth()+1;
    return Math.ceil(monthIndex/3)===q;
  });
  if(months.length===0) return `<div class="card">Q${q}<br>Ingen data</div>`;

  let totalK=0,totalB=0,totalS=0;
  months.forEach(m=>{
    const net=m.revenueGross/vatFactor;
    totalK+=calcPercent(m.kitchen,net);
    totalB+=calcPercent(m.bar,net);
    totalS+=calcPercent(m.salary,net);
  });
  const avgK=totalK/months.length;
  const score=Math.max(0,100-(Math.max(avgK-dep.budgets.kitchen,0)*10));

  return `
  <div class="card">
    <h3>Q${q}</h3>
    <div>Køkken ${avgK.toFixed(1)}%</div>
    <div>Score ${score.toFixed(0)}</div>
  </div>`;
}

function renderYearChart(months,dep){
  if(chartInstance) chartInstance.destroy();
  chartInstance=new Chart(document.getElementById("yearChart"),{
    type:"line",
    data:{
      labels:months.map(m=>m.month),
      datasets:[
        {
          label:"Køkken %",
          data:months.map(m=>calcPercent(m.kitchen,getRevenueNet(m))),
          borderColor:"#22c55e"
        }
      ]
    },
    options:{
      plugins:{legend:{labels:{color:"white"}}},
      scales:{
        x:{ticks:{color:"white"}},
        y:{ticks:{color:"white"}}
      }
    }
  });
}

function changeYear(){renderYear();}

if("serviceWorker" in navigator){
  navigator.serviceWorker.register("service-worker.js");
}

renderDashboard();

</script>
</body>
</html>
